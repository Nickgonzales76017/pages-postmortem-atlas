      "semantic_score": 0.297,
      "formant_ratio": 0.519,
      "token_count": 16,
      "speaker_turn": false,
      "text": " and you want to inspect what happened and try and learn from it."
    },
    {
      "t0_ms": 59520,
      "t1_ms": 65760,
      "confidence": 0.9375,
      "quality": 0.9375,
      "hcp_quality": 1.0000,
      "hallucination_flags": 0,
      "hcp_flagged_tokens": 4,
