      "semantic_score": 0.209,
      "formant_ratio": 0.635,
      "token_count": 16,
      "speaker_turn": false,
      "text": " The way forward is to learn from failure to become proactive instead of reactive."
    },
    {
      "t0_ms": 35440,
      "t1_ms": 39280,
      "confidence": 0.7501,
      "quality": 0.7501,
