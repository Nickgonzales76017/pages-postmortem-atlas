      "semantic_score": 0.116,
      "formant_ratio": 0.627,
      "token_count": 19,
      "speaker_turn": false,
      "text": " where people would rather cover up their tracks than be honest. And such an unsafe environment"
    },
    {
      "t0_ms": 90720,
      "t1_ms": 97040,
      "confidence": 0.9808,
      "quality": 0.9808,
      "hcp_quality": 1.0000,
      "hallucination_flags": 0,
      "hcp_flagged_tokens": 5,
      "et_rms": 0.0965,
      "et_speech_frac": 0.80,
