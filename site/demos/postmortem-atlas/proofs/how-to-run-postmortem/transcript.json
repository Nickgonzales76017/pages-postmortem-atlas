      "semantic_score": 0.225,
      "formant_ratio": 0.719,
      "token_count": 18,
      "speaker_turn": false,
      "text": " But wouldn't it be better if you would have a process of analyzing what happened?"
    },
    {
      "t0_ms": 23600,
      "t1_ms": 28240,
      "confidence": 0.9429,
