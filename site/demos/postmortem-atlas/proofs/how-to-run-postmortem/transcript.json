      "semantic_score": 0.061,
      "formant_ratio": 0.673,
      "token_count": 22,
      "speaker_turn": false,
      "text": " specific failure. Something maybe last week happened, maybe your web app was down or your API was down,"
    },
    {
      "t0_ms": 56320,
      "t1_ms": 59520,
      "confidence": 0.9904,
      "quality": 0.9904,
      "hcp_quality": 1.0000,
